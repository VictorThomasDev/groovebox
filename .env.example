# ── Database ────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://groovebox:groovebox@localhost:5432/groovebox"
POSTGRES_USER=groovebox
POSTGRES_PASSWORD=groovebox
POSTGRES_DB=groovebox

# ── API server ───────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── Auth ─────────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-in-production-use-a-long-random-string
JWT_EXPIRES_IN=7d

# ── Discogs API ───────────────────────────────────────────────────────────────
DISCOGS_CONSUMER_KEY=your_consumer_key
DISCOGS_CONSUMER_SECRET=your_consumer_secret
DISCOGS_USER_AGENT=Groovebox/1.0 +https://github.com/you/groovebox

# ── Frontend ──────────────────────────────────────────────────────────────────
VITE_API_URL=http://localhost:3000
FRONTEND_URL=http://localhost:5173
